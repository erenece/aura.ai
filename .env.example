# ════════════════════════════════════════════════
#  MODUS AI — .env Ayar Dosyası
#  Bu dosyayı .env olarak kaydet ve doldur.
# ════════════════════════════════════════════════

# ── Zorunlu: Gemini AI ───────────────────────────
GEMINI_API_KEY=buraya_gemini_api_anahtarinizi_yazin
# https://aistudio.google.com/app/apikey adresinden ücretsiz al

# ── Zorunlu: Güvenlik ────────────────────────────
JWT_SECRET=cok_uzun_rastgele_bir_seyler_yaz_buraya_mesela_modus2026supersecret


# ════════════════════════════════════════════════
#  E-POSTA — ikisinden birini doldur, ikisi de olursa Resend önce dener
# ════════════════════════════════════════════════

# YÖNTEM 1 — Resend (EN KOLAY) ──────────────────
# resend.com → üye ol → API Keys → Create → kopyala
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Kendi domain'in varsa: "Modus AI <bildirim@siteadresi.com>"
# Yoksa bu şekilde bırak (sadece test alıcısına gönderir):
RESEND_FROM=Modus AI <onboarding@resend.dev>

# YÖNTEM 2 — Gmail (uygulama şifresi gerekli) ───
# SMTP_USER=senin@gmail.com
# SMTP_PASSWORD=abcdefghijklmnop   ← Gmail > Güvenlik > Uygulama Şifresi


# ════════════════════════════════════════════════
#  WHATSAPP — ikisinden birini doldur
# ════════════════════════════════════════════════

# YÖNTEM 1 — CallMeBot (TAMAMEN BEDAVA) ──────────
# 1. WhatsApp'tan +34 644 93 01 08 numarasına şunu gönder:
#    "I allow callmebot to send me messages"
# 2. Gelen API key'i buraya yaz:
CALLMEBOT_APIKEY=123456
# Kendi telefon numaran (90 ile başlat, 0'ı at):
CALLMEBOT_PHONE=905001234567

# YÖNTEM 2 — Meta Business API (müşterilere gönderim) ─
# WHATSAPP_TOKEN=EAABxxxxxxxxxxxx
# WHATSAPP_PHONE_ID=123456789012345


# ════════════════════════════════════════════════
#  KARGO API (isteğe bağlı, yoksa demo veri gösterir)
# ════════════════════════════════════════════════
# YURTICI_API_KEY=
# MNG_API_KEY=
# PTT_API_KEY=


# ════════════════════════════════════════════════
#  TWILIO (WhatsApp — gelen mesajları alma)
# ════════════════════════════════════════════════
# twilio.com → Console → Messaging → WhatsApp Sandbox
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=+14155238886

# ════════════════════════════════════════════════
#  PROAKTİF İZLEME
# ════════════════════════════════════════════════
# Yöneticinin WhatsApp numarası (uluslararası format: +905XXXXXXXXX)
ADMIN_PHONE=+905001234567
# Gecikme/stok kontrol aralığı saniye cinsinden (demo için 60, üretim için 3600)
PROACTIVE_CHECK_INTERVAL=3600

# Meta WhatsApp webhook doğrulama token'ı (istediğiniz bir değer)
WHATSAPP_VERIFY_TOKEN=modus_verify_2026

# ── Diğer ────────────────────────────────────────
DEBUG=false
LOW_STOCK_THRESHOLD=10
